# DeepSeek API Configuration
# Get your API key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-api-key-here

# Optional: Model selection (default: deepseek-v4-pro)
# Available: deepseek-v4-pro, deepseek-v4-flash
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: API base URL (default: https://api.deepseek.com)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Bilibili Cookie (optional, needed for CC subtitles on Bilibili)
# 1. Open bilibili.com in browser (login first)
# 2. F12 → Application → Cookies → bilibili.com
# 3. Copy the value of SESSDATA
# BILIBILI_SESSDATA=

# ─── Stripe Configuration ───────────────────────────────────────────────────
# 1. Sign up at https://dashboard.stripe.com/register
# 2. Get your test keys at https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# 3. Create a product + price at https://dashboard.stripe.com/test/products
#    Name: "VideoDown PRO", Price: $4.99/month (subscription)
STRIPE_PRO_PRICE_ID=price_your_price_id_here

# 4. Webhook secret from `stripe listen --forward-to localhost:8000/api/webhook/stripe`
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# ─── JWT Secret ─────────────────────────────────────────────────────────────
# Auto-generated if not set. Set a persistent value for production
# so tokens survive server restarts.
# JWT_SECRET=generate-a-random-string-here
