# DeepSeek API Configuration
# Get your API key at: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=sk-your-api-key-here

# Optional: Model selection (default: deepseek-v4-pro)
# Available: deepseek-v4-pro, deepseek-v4-flash
DEEPSEEK_MODEL=deepseek-v4-pro

# Optional: API base URL (default: https://api.deepseek.com)
# DEEPSEEK_BASE_URL=https://api.deepseek.com

# Bilibili Cookie (optional, needed for CC subtitles on Bilibili)
# 1. Open bilibili.com in browser (login first)
# 2. F12 → Application → Cookies → bilibili.com
# 3. Copy the value of SESSDATA
# BILIBILI_SESSDATA=
